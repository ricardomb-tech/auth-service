# Copiar a .env y ajustar. Nunca commitear .env con secretos reales (AD-10, AD-19).

# ===============================
# DATABASE
# ===============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_service
DB_USER=auth_service
DB_PASSWORD=auth_service

# ===============================
# JWT (AD-3, AD-19 — par activo+anterior para rotación sin downtime)
# ===============================
JWT_SECRET_CURRENT=change-me-to-a-256-bit-random-secret
JWT_SECRET_PREVIOUS=

# ===============================
# OAUTH2
# ===============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===============================
# ADMIN INICIAL (FR-12)
# ===============================
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=

# ===============================
# EMAIL (dev: MailHog en docker-compose.yml)
# ===============================
MAIL_HOST=localhost
MAIL_PORT=1025

# ===============================
# EVENTOS DE DOMINIO (AD-15 — Redpanda en docker-compose.yml)
# ===============================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===============================
# APP
# ===============================
APP_BASE_URL=http://localhost:8080
